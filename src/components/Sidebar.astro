---
import { getCollection } from 'astro:content';

const sections = (await getCollection('sections')).sort((a, b) => a.data.order - b.data.order);
const currentPath = Astro.url.pathname.replace(/\/$/, '');
---

<nav class="sidebar">
  <div class="brand">
    <a href="/" class="brand-link">
      <img src="/favicon.svg" alt="Logo" class="brand-logo" width="24" height="24" data-no-lightbox />
      <div>
        <p class="brand-title">cliente.com</p>
        <p class="brand-sub">Auditoría técnica · Mayo 2026</p>
      </div>
    </a>
    <button class="theme-toggle" data-theme-toggle aria-label="Cambiar tema claro/oscuro" title="Tema claro/oscuro">
      <svg class="icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
      <svg class="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
    </button>
  </div>

  <div class="nav-section">
    <button class="cmdk-trigger" data-cmdk-open type="button">
      <span class="cmdk-trigger-label">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        Buscar sección
      </span>
      <kbd class="cmdk-trigger-kbd">⌘K</kbd>
    </button>
  </div>

  <div class="nav-section">
    <a
      href="/"
      class:list={["nav-item", { active: currentPath === '' || currentPath === '/' }]}
    >
      Resumen ejecutivo
    </a>
  </div>

  <div class="nav-divider"></div>
  <p class="nav-label">Análisis</p>

  <div class="nav-section">
    {sections.slice(0, 6).map(section => (
      <a
        href={`/${section.data.slug}`}
        class:list={["nav-item", { active: currentPath === `/${section.data.slug}` }]}
      >
        <span class="nav-num">{String(section.data.order).padStart(2, '0')}</span>
        {section.data.title}
      </a>
    ))}
  </div>

  <div class="nav-divider"></div>
  <p class="nav-label">Resultado</p>

  <div class="nav-section">
    {sections.slice(6).map(section => (
      <a
        href={`/${section.data.slug}`}
        class:list={["nav-item", { active: currentPath === `/${section.data.slug}` }]}
      >
        <span class="nav-num">{String(section.data.order).padStart(2, '0')}</span>
        {section.data.title}
      </a>
    ))}
  </div>
</nav>

<style>
  /* En móvil el toggle de tema ya está en el header; ocultamos el del drawer para no duplicarlo */
  @media (max-width: 768px) {
    .sidebar .theme-toggle {
      display: none;
    }
  }

  .sidebar {
    width: 240px;
    height: 100%;
    background: var(--surface-2);
    border-right: 1px solid var(--border-soft);
    padding: 1.5rem 0;
    overflow-y: auto;
  }

  .brand {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 0 1.25rem 1.25rem;
    border-bottom: 1px solid var(--border-soft);
    margin-bottom: 1rem;
  }

  .brand-link {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    text-decoration: none;
    min-width: 0;
  }

  .brand-logo {
    width: 24px;
    height: 24px;
    border-radius: 4px;
    flex-shrink: 0;
    display: block;
    cursor: default;
    pointer-events: none;
  }

  .brand-title {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--text);
    margin: 0;
    line-height: 1.2;
  }

  .brand-sub {
    font-size: 0.7rem;
    color: var(--text-faint);
    margin: 0;
    margin-top: 2px;
  }

  .nav-section {
    padding: 0 0.75rem;
  }

  .cmdk-trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    gap: 0.5rem;
    padding: 0.45rem 0.625rem;
    margin-bottom: 0.25rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: var(--surface);
    color: var(--text-muted);
    cursor: pointer;
    font-family: inherit;
    transition: border-color 0.12s, color 0.12s;
  }
  .cmdk-trigger:hover {
    border-color: var(--brand);
    color: var(--brand);
  }
  .cmdk-trigger-label {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
  }
  .cmdk-trigger-kbd {
    font-size: 0.65rem;
    font-family: 'Fira Code', monospace;
    color: var(--text-faint);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.05rem 0.3rem;
  }

  .nav-label {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-faint);
    padding: 0 1.25rem;
    margin: 0 0 0.375rem;
  }

  .nav-divider {
    height: 1px;
    background: var(--border-soft);
    margin: 0.875rem 1.25rem;
  }

  .nav-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.625rem;
    border-radius: 6px;
    font-size: 0.8125rem;
    color: var(--text-muted);
    text-decoration: none;
    transition: background 0.12s, color 0.12s;
    line-height: 1.4;
  }

  .nav-item:hover {
    background: var(--brand-tint);
    color: var(--brand);
  }

  .nav-item.active {
    background: var(--brand-tint);
    color: var(--brand);
    font-weight: 600;
  }

  .nav-num {
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--num-faint);
    min-width: 1.25rem;
    font-variant-numeric: tabular-nums;
    flex-shrink: 0;
  }

  .nav-item.active .nav-num {
    color: var(--brand);
    opacity: 0.5;
  }
</style>
