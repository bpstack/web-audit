---
import '../styles/global.css';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="description" content="Documento privado. Acceso restringido por invitación." />
    <title>Acceso restringido — Auditoría cliente.com</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <script is:inline>
      (() => {
        try {
          const stored = localStorage.getItem('theme');
          const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          if (stored === 'dark' || (!stored && prefersDark)) {
            document.documentElement.classList.add('dark');
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body class="restricted-body">
    <div class="restricted-backdrop" aria-hidden="true"></div>

    <main class="restricted-modal" role="dialog" aria-modal="true" aria-labelledby="restricted-title">
      <div class="restricted-icon" aria-hidden="true">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
          <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
        </svg>
      </div>

      <span class="restricted-eyebrow">Documento privado</span>
      <h1 id="restricted-title" class="restricted-title">Acceso por invitación</h1>

      <p class="restricted-lede">
        Este informe forma parte de un análisis técnico privado. El acceso está restringido a los
        destinatarios autorizados por el autor.
      </p>

      <div class="restricted-card">
        <p class="restricted-card-label">Acceso de demostración</p>
        <p class="restricted-card-text">
          El informe está protegido por un control de acceso mediante token, implementado como
          demostración técnica y desactivable en cualquier momento. Pincha en el siguiente enlace
          para obtener <strong>acceso temporal</strong> a la auditoría.
        </p>

        <div class="restricted-actions">
          <a class="restricted-btn restricted-btn-primary" href="/unlock?token=salvador-2026-x9k2">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M7 11V7a5 5 0 0 1 9.9-1"></path>
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
            </svg>
            Acceso al informe
          </a>
          <a class="restricted-btn restricted-btn-secondary" href="https://www.stackbp.es/" target="_blank" rel="noopener noreferrer">
            Ver portfolio
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M7 17 17 7"></path>
              <path d="M7 7h10v10"></path>
            </svg>
          </a>
        </div>
      </div>

      <p class="restricted-footnote">
        La sesión de acceso expira automáticamente a las 2 horas. El control puede deshabilitarse
        en cualquier momento desde el panel de despliegue.
      </p>
    </main>

    <style>
      :root {
        color-scheme: light dark;
      }

      .restricted-body {
        margin: 0;
        min-height: 100vh;
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        background:
          radial-gradient(1200px 600px at 20% -10%, color-mix(in oklab, var(--brand, #6366f1) 22%, transparent), transparent 60%),
          radial-gradient(900px 500px at 100% 110%, color-mix(in oklab, var(--brand, #6366f1) 14%, transparent), transparent 55%),
          var(--bg, #0b0c10);
        color: var(--text, #e6e8eb);
        display: grid;
        place-items: center;
        padding: 1.5rem;
        overflow: hidden;
        position: relative;
      }

      .restricted-backdrop {
        position: fixed;
        inset: 0;
        backdrop-filter: blur(8px);
        background: color-mix(in oklab, var(--bg, #0b0c10) 55%, transparent);
        pointer-events: none;
      }

      .restricted-modal {
        position: relative;
        z-index: 1;
        max-width: 520px;
        width: 100%;
        padding: 2.5rem 2rem;
        border-radius: 20px;
        background: color-mix(in oklab, var(--surface, #14161c) 92%, transparent);
        border: 1px solid color-mix(in oklab, var(--border, #2a2d36) 80%, transparent);
        box-shadow:
          0 1px 0 color-mix(in oklab, white 6%, transparent) inset,
          0 30px 80px -20px rgba(0, 0, 0, 0.6),
          0 10px 30px -10px rgba(0, 0, 0, 0.45);
        text-align: left;
        animation: restricted-in 420ms cubic-bezier(0.2, 0.8, 0.2, 1) both;
      }

      @keyframes restricted-in {
        from { opacity: 0; transform: translateY(8px) scale(0.985); }
        to   { opacity: 1; transform: translateY(0)   scale(1); }
      }

      .restricted-icon {
        width: 56px;
        height: 56px;
        border-radius: 14px;
        display: grid;
        place-items: center;
        background: color-mix(in oklab, var(--brand, #6366f1) 18%, transparent);
        color: var(--brand, #6366f1);
        border: 1px solid color-mix(in oklab, var(--brand, #6366f1) 35%, transparent);
        margin-bottom: 1.25rem;
      }

      .restricted-eyebrow {
        display: inline-block;
        font-size: 0.72rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: color-mix(in oklab, var(--text, #e6e8eb) 60%, transparent);
        margin-bottom: 0.5rem;
      }

      .restricted-title {
        font-size: clamp(1.5rem, 2.4vw, 1.9rem);
        font-weight: 700;
        margin: 0 0 0.75rem;
        letter-spacing: -0.015em;
        line-height: 1.2;
      }

      .restricted-lede {
        margin: 0 0 1.5rem;
        color: color-mix(in oklab, var(--text, #e6e8eb) 78%, transparent);
        line-height: 1.55;
        font-size: 0.97rem;
      }

      .restricted-card {
        padding: 1.25rem;
        border-radius: 14px;
        background: color-mix(in oklab, var(--bg, #0b0c10) 55%, transparent);
        border: 1px solid color-mix(in oklab, var(--border, #2a2d36) 80%, transparent);
        margin-bottom: 1.25rem;
      }

      .restricted-card-label {
        margin: 0 0 0.35rem;
        font-size: 0.78rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: color-mix(in oklab, var(--text, #e6e8eb) 55%, transparent);
      }

      .restricted-card-text {
        margin: 0 0 1rem;
        font-size: 0.95rem;
        line-height: 1.5;
        color: color-mix(in oklab, var(--text, #e6e8eb) 88%, transparent);
      }

      .restricted-card-text strong { color: var(--text, #e6e8eb); }

      .restricted-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem;
      }

      .restricted-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.65rem 1rem;
        border-radius: 10px;
        font-size: 0.9rem;
        font-weight: 600;
        text-decoration: none;
        transition: transform 0.15s ease, background 0.15s ease, border-color 0.15s ease;
        border: 1px solid transparent;
      }

      .restricted-btn:hover { transform: translateY(-1px); }

      .restricted-btn-primary {
        background: var(--brand, #6366f1);
        color: #fff;
      }
      .restricted-btn-primary:hover {
        background: color-mix(in oklab, var(--brand, #6366f1) 88%, white);
      }

      .restricted-btn-secondary {
        background: transparent;
        color: var(--text, #e6e8eb);
        border-color: color-mix(in oklab, var(--border, #2a2d36) 100%, transparent);
      }
      .restricted-btn-secondary:hover {
        border-color: color-mix(in oklab, var(--brand, #6366f1) 60%, transparent);
        color: var(--brand, #6366f1);
      }

      .restricted-footnote {
        margin: 0;
        font-size: 0.82rem;
        color: color-mix(in oklab, var(--text, #e6e8eb) 50%, transparent);
        line-height: 1.5;
      }

      @media (max-width: 480px) {
        .restricted-modal { padding: 2rem 1.5rem; border-radius: 16px; }
        .restricted-actions { flex-direction: column; align-items: stretch; }
        .restricted-btn { justify-content: center; }
      }
    </style>
  </body>
</html>
